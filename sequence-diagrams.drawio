          <mxGeometry x="260" y="72" width="160" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="p4-mgr" value="McpServerManager&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="460" y="72" width="180" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="p4-cli" value="McpStdioClient&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="680" y="72" width="180" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="p4-proc" value="MCP subprocess&#10;(stdio)" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="900" y="72" width="180" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="p4-ce" value="CompositeToolExecutor&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1120" y="72" width="200" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="p4-cr" value="ConversationRuntime&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1360" y="72" width="200" height="920" as="geometry"/>
        </mxCell>

        <!-- per-server loop frame -->
        <mxCell id="p4-loop" value="loop  [per configured MCP server in RuntimeConfig.mcp]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6C8EBF;fontSize=11;fontStyle=2;align=left;verticalAlign=top;spacingLeft=8;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="460" y="230" width="620" height="440" as="geometry"/>
        </mxCell>

        <!-- messages: bootstrap -->
        <mxCell id="m4-01" value="load(workingDir)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="130" y="130" as="sourcePoint"/><mxPoint x="340" y="130" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-02" value="RuntimeConfig { mcp: {name → McpServerConfig} }" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="170" as="sourcePoint"/><mxPoint x="130" y="170" as="targetPoint"/></mxGeometry>
        </mxCell>
