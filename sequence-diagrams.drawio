          </mxGeometry>
        </mxCell>

        <!-- composite wiring + later call -->
        <mxCell id="m4-15" value="compose(Builtin + MCP-backed adapters)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
