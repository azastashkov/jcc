          <mxGeometry relative="1" as="geometry"><mxPoint x="130" y="210" as="sourcePoint"/><mxPoint x="550" y="210" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- lifecycle loop -->
        <mxCell id="m4-04" value="spawn(name, config, executor)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="260" as="sourcePoint"/><mxPoint x="770" y="260" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-05" value="ProcessBuilder.start()" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="295" as="sourcePoint"/><mxPoint x="990" y="295" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-06" value="startReaders()  (virtual threads drain stdout + stderr)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#82B366;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="330" as="sourcePoint"/>
            <mxPoint x="770" y="355" as="targetPoint"/>
            <Array as="points"><mxPoint x="835" y="330"/><mxPoint x="835" y="355"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4-07" value="initialize()  (timeout 10 s)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="390" as="sourcePoint"/><mxPoint x="770" y="390" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-08" value="JSON-RPC  initialize { protocolVersion, clientInfo }" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="425" as="sourcePoint"/><mxPoint x="990" y="425" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-09" value="result { protocolVersion, capabilities }" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="990" y="460" as="sourcePoint"/><mxPoint x="770" y="460" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-10" value="notifications/initialized  (fire-and-forget)" style="endArrow=open;html=1;fontSize=11;strokeColor=#D79B00;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="495" as="sourcePoint"/><mxPoint x="990" y="495" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-11" value="listTools()  (timeout 30 s)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="535" as="sourcePoint"/><mxPoint x="770" y="535" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-12" value="JSON-RPC  tools/list" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="570" as="sourcePoint"/><mxPoint x="990" y="570" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-13" value="tools[]" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="990" y="605" as="sourcePoint"/><mxPoint x="770" y="605" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4-14" value="register as mcp__&lt;server&gt;__&lt;tool&gt;" style="endArrow=classic;html=1;fontSize=11;strokeColor=#82B366;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
