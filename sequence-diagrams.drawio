  <!-- =========================================================
       Diagram 5 — sub-agent delegation via AgentTool
       ========================================================= -->
  <diagram name="5. Sub-agent delegation" id="seq-5-subagent">
    <mxGraphModel dx="1900" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1840" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t5" value="5 · Sub-agent delegation  —  AgentTool  →  SubagentExecutor  →  child ConversationRuntime" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1760" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="t5s" value="Parent issues tool_use {name: Agent} · child runs with FilteringToolExecutor (per-type allowlist) and a system prompt" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="42" width="1760" height="20" as="geometry"/>
        </mxCell>

        <!-- lifelines -->
        <mxCell id="p5-prov" value="ProviderClient&#10;(parent stream)&#10;«api»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=50;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="160" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-parent" value="Parent&#10;ConversationRuntime&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=50;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="240" y="72" width="200" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-agent" value="AgentTool&#10;«tools»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="480" y="72" width="160" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-se" value="SubagentExecutor&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="680" y="72" width="180" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-allow" value="SubagentToolAllowlist&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="900" y="72" width="200" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-tr" value="TaskRegistry&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1140" y="72" width="170" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-ftool" value="FilteringToolExecutor&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=40;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1350" y="72" width="200" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="p5-child" value="Child&#10;ConversationRuntime&#10;«runtime»" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=12;fontStyle=1;size=50;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1590" y="72" width="200" height="820" as="geometry"/>
        </mxCell>

        <!-- messages -->
        <mxCell id="m5-01" value="tool_use { name: Agent, input: { description, prompt, subagent_type, model? } }" style="endArrow=open;html=1;fontSize=11;strokeColor=#6C8EBF;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="120" y="140" as="sourcePoint"/><mxPoint x="340" y="140" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-02" value="execute(&quot;Agent&quot;, input, ctx)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="180" as="sourcePoint"/><mxPoint x="560" y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-03" value="run(description, prompt, type, modelOverride)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="220" as="sourcePoint"/><mxPoint x="770" y="220" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-04" value="allowedTools(subagent_type)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="260" as="sourcePoint"/><mxPoint x="1000" y="260" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-05" value="Set&lt;String&gt;  (e.g. {read_file, glob, grep})" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="300" as="sourcePoint"/><mxPoint x="770" y="300" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-06" value="new FilteringToolExecutor(parentTools, allowed)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="340" as="sourcePoint"/><mxPoint x="1450" y="340" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-07" value="createTask(description, type)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="380" as="sourcePoint"/><mxPoint x="1225" y="380" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-08" value="TaskRecord { taskId, status: PENDING }" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1225" y="420" as="sourcePoint"/><mxPoint x="770" y="420" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-09" value="transition(taskId, RUNNING, current thread)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="460" as="sourcePoint"/><mxPoint x="1225" y="460" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-10" value="new ConversationRuntime(provider, filtered, perms, …, systemPrompt)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="500" as="sourcePoint"/><mxPoint x="1690" y="500" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-11" value="runTurn(prompt, AssistantEventHandler.NOOP)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="540" as="sourcePoint"/><mxPoint x="1690" y="540" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-12" value="(inner tool loop — see Diagram 1, filtered tool surface)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#6C8EBF;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1690" y="580" as="sourcePoint"/>
            <mxPoint x="1690" y="605" as="targetPoint"/>
            <Array as="points"><mxPoint x="1760" y="580"/><mxPoint x="1760" y="605"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m5-13" value="TurnSummary  (finalText, usage, stop_reason)" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1690" y="640" as="sourcePoint"/><mxPoint x="770" y="640" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-14" value="transition(taskId, COMPLETED, finalText)   |   FAILED on RuntimeException" style="endArrow=classic;html=1;fontSize=11;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="680" as="sourcePoint"/><mxPoint x="1225" y="680" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-15" value="SubagentResult { finalText, usage, status, taskId }" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="770" y="720" as="sourcePoint"/><mxPoint x="560" y="720" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-16" value="Result.Ok(ToolOutput(finalText))" style="endArrow=open;html=1;fontSize=11;strokeColor=#888888;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="760" as="sourcePoint"/><mxPoint x="340" y="760" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5-17" value="next turn: user msg with tool_result block  (→ parent model continues)" style="endArrow=classic;html=1;fontSize=11;strokeColor=#6C8EBF;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="800" as="sourcePoint"/><mxPoint x="120" y="800" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- note -->
        <mxCell id="n5" value="System prompt (hard-coded):&#10;&quot;You are a background sub-agent of type `…`.&#10; Work only on the delegated task, use only&#10; the tools available to you, do not ask the&#10; user questions, and finish with a concise&#10; result.&quot;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="680" y="110" width="440" height="85" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

