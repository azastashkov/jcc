  <!-- =========================================================
       Diagram 3 — tool call with permission gate
       ========================================================= -->
  <diagram name="3. Tool call + permission" id="seq-3-tool">
    <mxGraphModel dx="1800" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
