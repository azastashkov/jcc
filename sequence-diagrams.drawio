        <!-- note -->
        <mxCell id="n4" value="writeLock + ConcurrentHashMap&lt;id, CompletableFuture&gt;&#10;pair stdin writes with async stdout responses.&#10;stderr is drained into SLF4J at DEBUG.&#10;Shutdown: stdin.close + waitFor(5s) + destroyForcibly." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
